# DRB OCR AI V2 machine profile: Basler camera + Mitsubishi PLC over SLMP/MC Protocol

DRB_V2_CAMERA_VENDOR=basler
DRB_V2_CAMERA_SERIAL=
DRB_V2_CAMERA_IP=
DRB_V2_CAMERA_USER_SET=
DRB_V2_CAMERA_SDK_PATH=
DRB_V2_CAMERA_ACQUISITION_MODE=continuous

DRB_V2_PLC_VENDOR=mitsubishi
DRB_V2_PLC_PROTOCOL=slmp
DRB_V2_PLC_IP=192.168.0.250
DRB_V2_PLC_PORT=5000
DRB_V2_PLC_TRIES=1
DRB_V2_PLC_TYPE=Q
DRB_V2_PLC_COMM_TYPE=binary

# M-bit signal map for this case:
# M0   grab image
# M1   stop machine
# M2   start machine
# M100 light output
# M101 error pulse
