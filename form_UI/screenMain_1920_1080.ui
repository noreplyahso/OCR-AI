    <property name="styleSheet">
     <string notr="true">QToolBox QWidget {
    background-color: white;
}
QToolBox::tab {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #4A90E2, stop:1 #357ABD
    );
    color: white;              /* màu chữ */
    border: 1px solid #2C5AA0;
    border-radius: 4px;
    padding: 5px;
}

QToolBox::tab:selected {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #5AA0F2, stop:1 #3F7BD5
    );
    font-weight: bold;         /* chữ đậm khi tab được chọn */
}

QToolBox::tab:hover {
    background: #6AAFFF;
}</string>
