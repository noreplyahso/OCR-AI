                <string notr="true">QPushButton {
    background-color: #A6CAEE;
    border: 2px solid black;
    border-radius: 12px;
padding: 10px 10px;
}

QPushButton:hover {
    background-color: qlineargradient(
spread:pad, 
x1:0, y1:0, x2:0, y2:1, 

stop:0 #738B95, 
stop:1 #BAE5F5
    );
}

QPushButton:pressed {
    background-color: qlineargradient(
spread:pad, 
x1:0, y1:0, x2:0, y2:1, 
stop:0  #BAE5F5, 
stop:1 #738B95
);
    padding-top: 6px;   /* tạo cảm giác ấn xuống */
}</string>
